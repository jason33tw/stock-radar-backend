# FinMind API Token (從 https://finmindtrade.com/ 申請)
FINMIND_API_TOKEN=your_finmind_token_here

# LINE Messaging API (LINE Notify 已於 2025/3/31 停用，改用 Messaging API)
# 步驟:
#   1. 至 https://developers.line.biz/console/ 建立 Messaging API Channel
#   2. 取得 Channel Access Token (長期 Token)
#   3. 將 Bot 加為好友，並取得你的 User ID 或 Group ID
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_TARGET_ID=your_user_id_or_group_id_here

# 資料庫路徑
DATABASE_URL=sqlite:///./taiwan_stock_radar.db

# 應用程式設定
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# 每日更新時間 (收盤後，台灣時間 15:30)
UPDATE_HOUR=15
UPDATE_MINUTE=30

# 通知門檻分數
MIN_SCORE_FOR_NOTIFY=50
